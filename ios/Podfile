# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'IcePenguinStay' do
  config = use_native_modules!

  # Targeted modular headers for the Obj-C React pods that RNScreens 4.x imports from
  # Swift. We avoid global use_modular_headers! because it gives modulemaps to C++ React
  # pods (React-RuntimeCore, React-jsitooling, etc.) that share a `react_runtime/`
  # directory and end up redefining the same module.
  pod 'React-Core', :path => "#{config[:reactNativePath]}/", :modular_headers => true
  pod 'React-RCTImage', :path => "#{config[:reactNativePath]}/Libraries/Image", :modular_headers => true
  pod 'React-RCTAnimation', :path => "#{config[:reactNativePath]}/Libraries/NativeAnimation", :modular_headers => true
  pod 'React-RCTBlob', :path => "#{config[:reactNativePath]}/Libraries/Blob", :modular_headers => true
  pod 'React-RCTText', :path => "#{config[:reactNativePath]}/Libraries/Text", :modular_headers => true
  pod 'React-RCTLinking', :path => "#{config[:reactNativePath]}/Libraries/LinkingIOS", :modular_headers => true
  pod 'ReactCommon/turbomodule/core', :path => "#{config[:reactNativePath]}/ReactCommon", :modular_headers => true
  pod 'React-NativeModulesApple', :path => "#{config[:reactNativePath]}/ReactCommon/react/nativemodule/core/platform/ios", :modular_headers => true

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Patch fmt/base.h to force-disable consteval (Xcode 16+ "not a constant expression" fix)
    fmt_base = File.join(installer.sandbox.root, 'fmt/include/fmt/base.h')
    if File.exist?(fmt_base)
      contents = File.read(fmt_base)
      sentinel = '// Patched: force-disable consteval'
      unless contents.include?(sentinel)
        patched = contents.sub(
          /\/\/ Detect consteval, C\+\+20 constexpr extensions and std::is_constant_evaluated\.\n#if !defined\(__cpp_lib_is_constant_evaluated\).*?#endif\n/m,
          "// Detect consteval, C++20 constexpr extensions and std::is_constant_evaluated.\n#{sentinel} to fix Xcode 16+ build.\n#ifndef FMT_USE_CONSTEVAL\n#  define FMT_USE_CONSTEVAL 0\n#endif\n",
        )
        File.write(fmt_base, patched)
        Pod::UI.puts "Patched fmt/base.h to disable consteval".green
      end
    end

    # Fix Xcode 16+ compatibility for transitive C++ pods (fmt consteval, glog/Yoga -Werror)
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        # Allow non-modular includes inside framework modules. Needed because
        # `use_modular_headers!` (required for Swift pods like RNScreens 4.x) turns
        # React-* pods into framework modules, but React-Fabric / React-Core C++
        # headers contain legitimate non-modular includes that would otherwise
        # trigger -Werror=non-modular-include-in-framework-module.
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'

        if target.name == 'fmt'
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
          unless config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'].include?('FMT_USE_CONSTEVAL=0')
            config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'FMT_USE_CONSTEVAL=0'
          end
        end
        if ['glog', 'Yoga', 'SocketRocket', 'fmt'].include?(target.name)
          config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
          config.build_settings['CLANG_WARN_DOCUMENTATION_COMMENTS'] = 'NO'
          flags = config.build_settings['OTHER_CFLAGS'] || ['$(inherited)']
          flags = [flags] unless flags.is_a?(Array)
          flags << '-Wno-error' unless flags.include?('-Wno-error')
          config.build_settings['OTHER_CFLAGS'] = flags
          cpp_flags = config.build_settings['OTHER_CPLUSPLUSFLAGS'] || ['$(inherited)']
          cpp_flags = [cpp_flags] unless cpp_flags.is_a?(Array)
          cpp_flags << '-Wno-error' unless cpp_flags.include?('-Wno-error')
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = cpp_flags
        end
      end
    end
  end
end
